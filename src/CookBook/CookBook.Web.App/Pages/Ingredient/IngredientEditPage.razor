@page "/ingredients/create"
@page "/ingredients/{Id:guid}"
@namespace CookBook.Web.App.Pages
@using CookBook.Web.App.Resources.Texts
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@inherits PageBase
@inject IStringLocalizer<AppResources> AppResourcesLocalizer
@inject IStringLocalizer<IngredientEditPageResources> IngredientEditPageLocalizer
@attribute [Authorize]

<h1 class="mb-4">
    @IngredientEditPageLocalizer["Page_Title"]
    @if (IsLocalIngredient)
    {
        <span class="text-danger ml-1" title="@AppResourcesLocalizer["LocalOnlyItem_Tooltip"]">&#9679;</span>
    }
</h1>

<IngredientEditForm Id="@Id" OnModification="NavigateBack" />
